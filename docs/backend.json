{
  "entities": {
    "Employee": {
      "title": "Employee",
      "description": "Represents an employee with their personal and bank details.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the employee." },
        "name": { "type": "string", "description": "Full name of the employee." },
        "designation": { "type": "string", "description": "Job title or designation." },
        "bankName": { "type": "string", "description": "Name of the bank." },
        "branch": { "type": "string", "description": "Bank branch name." },
        "accountNumber": { "type": "string", "description": "Bank account number." },
        "routing": { "type": "string", "description": "Bank routing number." }
      },
      "required": ["id", "name", "designation", "bankName", "branch", "accountNumber", "routing"]
    },
    "BankAdvice": {
      "title": "Bank Advice",
      "description": "Represents a bank payment advice document.",
      "type": "object",
      "properties": {
        "adviceNumber": { "type": "string" },
        "refNo": { "type": "string" },
        "subject": { "type": "string" },
        "debitAccount": { "type": "string" },
        "bankName": { "type": "string" },
        "bankBranch": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "narrative": { "type": "string" },
        "purpose": { "type": "string" },
        "context": { "type": "string" },
        "employees": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "employee": { "$ref": "#/backend/entities/Employee" },
              "netPayment": { "type": "number" }
            },
            "required": ["netPayment", "employee"]
          }
        },
        "status": { "type": "string", "enum": ["Draft", "Issued", "Archived"] },
        "totalAmount": { "type": "number" }
      },
      "required": ["adviceNumber", "subject", "date", "status", "totalAmount", "employees"]
    },
    "PrintSettings": {
      "title": "Print Settings",
      "description": "Configuration for printing documents.",
      "type": "object",
      "properties": {
        "companyLogoUrl": { "type": "string" },
        "companySealUrl": { "type": "string" },
        "watermarkEnabled": { "type": "boolean" },
        "watermarkUrl": { "type": "string" },
        "headerLine1": { "type": "string" },
        "headerLine2": { "type": "string" },
        "headerLine3": { "type": "string" },
        "headerLine4": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": []
  },
  "firestore": {
    "/employees/{employeeId}": {
      "schema": { "$ref": "#/backend/entities/Employee" },
      "description": "Stores individual employee records."
    },
    "/advices/{adviceId}": {
      "schema": { "$ref": "#/backend/entities/BankAdvice" },
      "description": "Stores bank advice documents."
    },
    "/settings/print": {
       "schema": { "$ref": "#/backend/entities/PrintSettings" },
       "description": "Stores application-wide print settings."
    }
  }
}
